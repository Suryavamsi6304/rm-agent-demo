pipeline {
    agent any

    parameters {
        string(name: 'VERSION', defaultValue: '', description: 'Docker image tag to deploy, for example: 1.2.0-B10')
    }

    environment {
        AWS_REGION = 'ap-southeast-2'
        ECR_REPOSITORY = 'rm-agent'
        NONPROD_LAMBDA = 'release-agent-nonprod1'
        IMAGE_TAG = "${params.VERSION}"
    }

    stages {
        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.VERSION?.trim()) {
                        error("VERSION is required")
                    }
                }
                echo "Deploying image tag VERSION=${params.VERSION} to Non-Prod"
            }
        }

        stage('Deploy to Non-Prod') {
            steps {
                withAWS(region: env.AWS_REGION, credentials: '099771438025') {
                    sh '''
                        set -e

                        AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
                        ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                        IMAGE_URI=${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}

                                                PACKAGE_TYPE=$(aws lambda get-function \
                                                    --function-name "${NONPROD_LAMBDA}" \
                                                    --region "${AWS_REGION}" \
                                                    --query 'Configuration.PackageType' \
                                                    --output text)

                                                if [ "${PACKAGE_TYPE}" != "Image" ]; then
                                                    echo "Deployment blocked: ${NONPROD_LAMBDA} package type is ${PACKAGE_TYPE}."
                                                    echo "This pipeline deploys ECR images only. Create/use an Image-type Lambda function."
                                                    exit 1
                                                fi


                        aws lambda update-function-code \
                          --function-name "${NONPROD_LAMBDA}" \
                          --image-uri "${IMAGE_URI}" \
                          --region "${AWS_REGION}"

                        echo "Non-Prod deployment successful"
                        echo "Image used: ${IMAGE_URI}"
                    '''
                }
            }
        }

        stage('Deployment Summary') {
            steps {
                sh '''
                    AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
                    ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                    IMAGE_URI=${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}

                    echo "=== Non-Prod Deployment Summary ===" > deploy-report.txt
                    echo "Version: ${IMAGE_TAG}" >> deploy-report.txt
                    echo "Environment: Non-Prod" >> deploy-report.txt
                    echo "Lambda: ${NONPROD_LAMBDA}" >> deploy-report.txt
                    echo "Image URI: ${IMAGE_URI}" >> deploy-report.txt
                    echo "Timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> deploy-report.txt

                    cat deploy-report.txt
                '''
                archiveArtifacts artifacts: 'deploy-report.txt', allowEmptyArchive: true
            }
        }
    }

    post {
        success {
            echo "Non-Prod deployment completed successfully for VERSION=${IMAGE_TAG}"
        }
        failure {
            echo "Non-Prod deployment failed for VERSION=${IMAGE_TAG}"
        }
        always {
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
    }
}