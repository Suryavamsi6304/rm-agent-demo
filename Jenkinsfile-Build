pipeline {
    agent any

    environment {
        AWS_REGION = 'us-east-1'
        S3_BUCKET = 'rm-planner-artifacts'
        ARTIFACT_BASE_NAME = 'lambda.zip'
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Checking out repository..."
                git branch: 'main', url: 'https://github.com/Suryavamsi6304/rm-agent-demo.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    node --version
                    npm --version
                    npm install
                '''
            }
        }

        stage('TypeCheck') {
            steps {
                sh 'npx tsc -p packages/api-server/tsconfig.json --noEmit'
            }
        }

        stage('Bundle Lambda') {
            steps {
                sh 'npm --workspace @rm/api-server run bundle'
            }
        }

        stage('Prepare Artifact Metadata') {
            steps {
                script {
                    env.ARTIFACT_VERSION = sh(script: "node -p \"require('./packages/api-server/package.json').version\"", returnStdout: true).trim()
                    env.ARTIFACT_NAME = "${env.ARTIFACT_BASE_NAME}:${env.ARTIFACT_VERSION}:B${env.BUILD_NUMBER}"
                    echo "Artifact name resolved as: ${env.ARTIFACT_NAME}"
                }
            }
        }

        stage('Prepare Lambda Package') {
            steps {
                sh '''
                    set -e

                    mkdir -p packages/api-server/dist/data
                    mkdir -p packages/api-server/dist/apps/release-planner-ui

                    cp generated-calendar-2026.json packages/api-server/dist/data/
                    cp -r apps/release-planner-ui/. packages/api-server/dist/apps/release-planner-ui/

                    cd packages/api-server/dist
                    zip -r lambda.zip lambda.js data/generated-calendar-2026.json apps/release-planner-ui
                    cd ../../..

                    echo "Lambda bundle created successfully"
                    ls -lh packages/api-server/dist/lambda.zip
                '''
            }
        }

        stage('Archive Artifacts') {
            steps {
                sh '''
                    mkdir -p build-artifacts
                    mkdir -p build-artifacts/${ARTIFACT_NAME}

                    cp packages/api-server/dist/lambda.zip build-artifacts/${ARTIFACT_NAME}/lambda.zip
                '''
            }
        }

        stage('Upload to S3') {
            steps {
                withAWS(region: env.AWS_REGION, credentials: 'aws-credentials') {
                    sh '''
                        S3_UPLOAD_PATH="s3://${S3_BUCKET}/"

                        aws s3 cp build-artifacts/${ARTIFACT_NAME}/lambda.zip ${S3_UPLOAD_PATH}${ARTIFACT_NAME}/lambda.zip

                        echo "Artifact uploaded to: ${S3_UPLOAD_PATH}${ARTIFACT_NAME}/lambda.zip"
                    '''
                }
            }
        }

        stage('Generate Build Report') {
            steps {
                sh '''
                    echo "=== Build Report ===" > build-report.txt
                    echo "Build Number: ${BUILD_NUMBER}" >> build-report.txt
                    echo "Build Timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> build-report.txt
                    echo "Git Commit: ${GIT_COMMIT}" >> build-report.txt
                    echo "Git Branch: ${GIT_BRANCH}" >> build-report.txt
                    echo "Lambda Artifact Folder: ${ARTIFACT_NAME}" >> build-report.txt
                    echo "S3 Location: s3://${S3_BUCKET}/${ARTIFACT_NAME}/lambda.zip" >> build-report.txt
                    echo "" >> build-report.txt
                    echo "=== Artifact Details ===" >> build-report.txt
                    ls -lh build-artifacts/${ARTIFACT_NAME}/ >> build-report.txt

                    cat build-report.txt
                '''
                archiveArtifacts artifacts: 'build-report.txt, packages/api-server/dist/lambda.zip', allowEmptyArchive: true
            }
        }
    }

    post {
        success {
            echo "Build completed successfully"
            echo "Artifact available at: s3://${S3_BUCKET}/${ARTIFACT_NAME}/lambda.zip"
            // build job: 'deploy-non-prod',
            //   wait: false,
            //   parameters: [
            //     string(name: 'BUILD_ID', value: "${env.BUILD_NUMBER}")
            //   ]
        }
        failure {
            echo "Build failed"
            sh 'rm -rf build-artifacts || true'
            
        }
        always {
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
    }
}
