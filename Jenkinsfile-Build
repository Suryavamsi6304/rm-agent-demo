pipeline {
    agent any

    parameters {
        string(name: 'BRANCH_NAME', defaultValue: 'main', description: 'Git branch to build')
        string(name: 'VERSION', defaultValue: 'latest', description: 'Docker image tag')
    }

    environment {
        AWS_REGION = 'us-east-1'
        ECR_REPOSITORY = 'rm-agent'
        IMAGE_TAG = "${params.VERSION}"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Checking out repository..."
                git branch: "${params.BRANCH_NAME}", url: 'https://github.com/Suryavamsi6304/rm-agent-demo.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                npm config set registry https://registry.npmjs.org/
                npm ci --no-audit --no-fund
                '''
            }
        }

        stage('TypeCheck') {
            steps {
                sh 'npm run typecheck'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    set -e

                    docker build \
                      -t ${ECR_REPOSITORY}:${IMAGE_TAG} \
                      -f Dockerfile \
                      .
                '''
            }
        }

        stage('Push to ECR') {
            steps {
                withAWS(region: env.AWS_REGION, credentials: 'aws-credentials') {
                    sh '''
                        set -e

                        AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
                        ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                        IMAGE_URI=${ECR_REGISTRY}/${ECR_REPOSITORY}:${IMAGE_TAG}

                        aws ecr describe-repositories --repository-names ${ECR_REPOSITORY} >/dev/null 2>&1 || \
                          aws ecr create-repository --repository-name ${ECR_REPOSITORY}

                        aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}

                        docker tag ${ECR_REPOSITORY}:${IMAGE_TAG} ${IMAGE_URI}

                        docker push ${IMAGE_URI}

                        echo "${IMAGE_URI}" > image-uri.txt

                        echo "Docker image uploaded to: ${IMAGE_URI}"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Build completed successfully"
            echo "Docker image published to ECR repository: ${ECR_REPOSITORY}"
            echo "Image tag: ${IMAGE_TAG}"
            // build job: 'deploy-non-prod',
            //   wait: false,
            //   parameters: [
            //     string(name: 'BUILD_ID', value: "${env.BUILD_NUMBER}")
            //   ]
        }
        failure {
            echo "Build failed"
            sh 'docker image rm ${ECR_REPOSITORY}:${IMAGE_TAG} || true'
            
        }
        always {
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
    }
}
